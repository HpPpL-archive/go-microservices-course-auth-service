# Copy this file to .env for local development and adjust values as needed.
# Values below are placeholders for local-only use; do not commit real secrets.

PG_DATABASE_NAME=auth
PG_USER=auth_user
PG_PASSWORD=change_me_local_password
PG_PORT=54321
MIGRATION_DIR=./migrations

PG_DSN="host=localhost port=54321 dbname=auth user=auth_user password=change_me_local_password sslmode=disable"
MIGRATION_DSN="host=pg port=5432 dbname=auth user=auth_user password=change_me_local_password sslmode=disable"

GRPC_HOST=localhost
GRPC_PORT=50051
